---
const categories = [
    { value: "sound", label: "Sounds" },
    { value: "sight", label: "Sights" },
    { value: "motion", label: "Motions" },
    { value: "word", label: "Words" },
];
---

<details class="newsletter-section" open>
    <summary>Get Updates</summary>
    <p>
        Give Us Your Email to get updated when we upload bullshit here within the day they are uploaded to the site
        <br><br>
        Examples are below
    </p>

    <form class="newsletter-form" data-newsletter-form>
        <label class="newsletter-form__field">
            <span>Email address</span>
            <input type="email" name="email" required autocomplete="email" />
        </label>

        <fieldset class="newsletter-form__field">
            <legend>What u wanna get notified for</legend>
            {
                categories.map((category) => (
                    <label class="newsletter-checkbox">
                        <input
                            type="checkbox"
                            name="categories"
                            value={category.value}
                            checked
                        />
                        <span>{category.label}</span>
                    </label>
                ))
            }
        </fieldset>

        {
            /* Honeypot fields for dumb bots that might fill them in, any non-default value will cause the signup to be rejected. The fields initially appear required, but use JS to make themselves optional upon form submit. CSS and tabindex effectively hides these from regular visitors but it probably messes up screenreaders etc. */
        }
        <label class="newsletter-checkbox h">
            <input type="checkbox" name="hConfirm" required tabindex="-1" />
            <span>Confirm signup</span>
        </label>
        <label class="newsletter-form__field h">
            <span>Name</span>
            <input type="text" name="hName" required tabindex="-1" />
        </label>

        <altcha-widget
            configuration={JSON.stringify({
                display: "invisible",
                hideLogo: true,
                hideFooter: true,
                language: "en",
                type: "checkbox",
                challenge: "/altcha-challenge",
                auto: "off",
            })}></altcha-widget>

        <button type="submit" class="newsletter-form__submit"> Sign up </button>
        <p
            class="newsletter-form__status"
            data-newsletter-message
            role="status"
            aria-live="polite"
        >
        </p>
    </form>
</details>

<style>
    .newsletter-section {
        display: grid;
        gap: var(--space-xs, 0.5lh);
        padding: var(--space-xs, 0.25lh) var(--space-sm, 1lh);
        border: var(--border-thickness, 1px) solid
            var(--text-color, currentColor);
        max-width: 32rem;
        justify-self: center;
    }

    .newsletter-form {
        display: grid;
        gap: var(--space-xs, 0.5lh);
    }

    .newsletter-form__field {
        display: grid;
        gap: var(--space-xs, 0.5lh);
    }

    .newsletter-checkbox {
        display: flex;
        gap: var(--space-xs, 0.5lh);
        align-items: center;
    }

    .newsletter-form__submit {
        width: fit-content;
    }

    .newsletter-form__status {
        margin: 0;
        min-height: 1lh;
        font-size: 0.9em;
    }

    .h {
        position: fixed;
        top: 110vh;
        left: 110vw;
        max-width: 300px;
    }
</style>

<script>
    import "altcha/external";
    import "altcha/altcha.css";
    import type { AltchaWidgetElement } from "altcha/external";
    import Pbkdf2Worker from "altcha/workers/pbkdf2?worker";

    // eslint-disable-next-line no-undef
    $altcha.algorithms.set("PBKDF2/SHA-256", () => new Pbkdf2Worker());

    document.addEventListener("DOMContentLoaded", () => {
        const form = document.querySelector<HTMLFormElement>(
            "form[data-newsletter-form]",
        );
        const widget =
            form?.querySelector<AltchaWidgetElement>("altcha-widget");
        if (form == null || widget == null) {
            return;
        }

        form.addEventListener("verifyaltcha", async () => {
            const result = await widget.verify();
            form.dispatchEvent(
                new CustomEvent("submitwithaltcha", {
                    detail: result?.payload,
                }),
            );
        });
    });
</script>

<script is:inline>
    const form = document.querySelector("[data-newsletter-form]");
    const message = document.querySelector("[data-newsletter-message]");
    const submitButton = form.querySelector('button[type="submit"]');

    const honeypotCheckbox = form.querySelector('input[name="hConfirm"]');
    const honeypotText = form.querySelector('input[name="hName"]');

    if (
        form instanceof HTMLFormElement &&
        message instanceof HTMLElement &&
        submitButton instanceof HTMLButtonElement &&
        honeypotCheckbox instanceof HTMLInputElement &&
        honeypotText instanceof HTMLInputElement
    ) {
        const honeypotInputs = [honeypotCheckbox, honeypotText];
        for (const honeypotInput of honeypotInputs) {
            honeypotInput.addEventListener("invalid", (event) => {
                event.preventDefault();

                honeypotInput.required = false;
                if (form.checkValidity()) {
                    setTimeout(() => form.requestSubmit(submitButton), 0);
                }
            });
        }

        let email;
        let categories;

        form.addEventListener("submit", async (event) => {
            event.preventDefault();

            submitButton.disabled = true;
            submitButton.textContent = "Sending…";

            message.textContent = "";

            categories = Array.from(
                form.querySelectorAll('input[name="categories"]:checked'),
            )
                .map((input) =>
                    input instanceof HTMLInputElement ? input.value : null,
                )
                .filter((value) => Boolean(value));

            const emailField = form.querySelector('input[name="email"]');
            email =
                emailField instanceof HTMLInputElement ? emailField.value : "";

            if (categories.length === 0) {
                message.textContent = "Select at least one category.";
                submitButton.disabled = false;
                submitButton.textContent = "Sign up";
                return;
            }

            form.dispatchEvent(new CustomEvent("verifyaltcha"));
        });

        form.addEventListener("submitwithaltcha", async (event) => {
            try {
                if (event.detail == null) {
                    message.textContent = "Verification failed.";
                    return;
                }

                const response = await fetch("/subscribe", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                        email,
                        categories,
                        h: [honeypotCheckbox.checked, honeypotText.value],
                        altcha: event.detail,
                    }),
                });

                const data = await response.json().catch(() => ({}));

                if (!response.ok) {
                    message.textContent =
                        data.error ?? "Something went wrong. Try again later.";
                } else if (data.status === "pendingVerification") {
                    form.reset();
                    message.textContent =
                        "Check your inbox for a verification email.";
                } else {
                    message.textContent = "Preferences saved. Thanks!";
                }
            } catch (error) {
                console.error("Failed to submit newsletter form", error);
                message.textContent =
                    "Could not submit the form. Try again later.";
            } finally {
                submitButton.disabled = false;
                submitButton.textContent = "Sign up";
            }
        });
    }
</script>
